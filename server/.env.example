NODE_ENV=production
PORT=5000

MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/roomradar
JWT_SECRET=replace-with-a-long-random-secret

CLIENT_URL=https://your-roomradar-domain.com
PUBLIC_APP_URL=https://your-roomradar-domain.com
ALLOWED_ORIGINS=https://your-roomradar-domain.com

JSON_BODY_LIMIT=2mb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=900
UPLOAD_MAX_FILE_MB=8

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

GEOAPIFY_API_KEY=your-geoapify-api-key

VAPID_SUBJECT=mailto:support@your-roomradar-domain.com
VAPID_PUBLIC_KEY=your-web-push-public-key
VAPID_PRIVATE_KEY=your-web-push-private-key

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROK_API_KEY=
GROK_MODEL=grok-2-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

PLATFORM_FEE=500
PLATFORM_FEE_PERCENTAGE=5
PLATFORM_COMMISSION_PERCENT=0
BOOKING_REQUEST_EXPIRY_HOURS=24
PAYOUT_HOLD_HOURS_AFTER_CHECKIN=24
DISPUTE_WINDOW_HOURS=72
ESCROW_ENABLED=true
OFFLINE_PAYMENT_ALLOWED=true
SUPPORT_EMAIL=support@your-roomradar-domain.com
PLATFORM_DEVELOPERS=RoomRadar Team
